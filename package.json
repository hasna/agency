{
  "name": "@hasna/cli",
  "version": "0.1.0",
  "description": "Unified management CLI for all @hasna/* open-source packages",
  "type": "module",
  "bin": {
    "hasna": "dist/cli/index.js"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "commander": "^12",
    "chalk": "^5",
    "@hasna/cloud": "^0.1.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "scripts": {
    "build": "bun build src/cli/index.ts --outdir dist/cli --target bun && tsc --emitDeclarationOnly --outDir dist || true",
    "test": "bun test"
  },
  "postinstall": "mkdir -p $HOME/.hasna/cli 2>/dev/null || true"
}
